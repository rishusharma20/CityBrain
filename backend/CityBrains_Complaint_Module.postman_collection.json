                  "    pm.expect(c).to.have.property('priority');",
                  "    pm.expect(c).to.have.property('status');",
                  "    pm.expect(c).to.have.property('department');",
                  "    pm.expect(c).to.have.property('location');",
                  "    pm.expect(c).to.have.property('address');",
                  "    pm.expect(c).to.have.property('wardNumber');",
                  "    pm.expect(c).to.have.property('createdBy');",
