{
  "info": {
    "name": "CityBrains — Complaint Management Module",
    "description": "Complete Postman collection for testing all 10 Complaint Management APIs.\n\n## Setup Instructions\n1. Import this collection into Postman\n2. Set the `BASE_URL` variable (default: http://localhost:8000)\n3. First run 'Auth → Register Citizen' and 'Auth → Login Citizen' to get a token\n4. The token is auto-saved to the collection variable `TOKEN`\n\n## Test Order\n1. Register & Login (Citizen, Officer, Admin)\n2. Create Complaint (as Citizen)\n3. Get All Complaints (as Admin/Officer)\n4. Get Complaint By ID\n5. Filter by Status / Category / Priority\n6. Get User Complaints (as Citizen)\n7. Get Duplicate Complaints\n8. Update Complaint (as Officer/Admin)\n9. Delete Complaint (as Admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000" },
    { "key": "TOKEN", "value": "" },
    { "key": "ADMIN_TOKEN", "value": "" },
    { "key": "OFFICER_TOKEN", "value": "" },
    { "key": "COMPLAINT_ID", "value": "" },
    { "key": "COMPLAINT_OBJECT_ID", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints to get JWT tokens for testing.",
      "item": [
        {
          "name": "Register Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Citizen\",\n  \"email\": \"citizen@citybrains.com\",\n  \"password\": \"citizen123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"Citizen\"\n}"
            }
          }
        },
        {
          "name": "Login Citizen",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('TOKEN', res.data.token);",
                  "    console.log('✅ Citizen token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen@citybrains.com\",\n  \"password\": \"citizen123\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('ADMIN_TOKEN', res.data.token);",
                  "    console.log('✅ Admin token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@citybrains.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login Officer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('OFFICER_TOKEN', res.data.token);",
                  "    console.log('✅ Officer token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"officer@citybrains.com\",\n  \"password\": \"officer123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "description": "All 10 Complaint Management Module endpoints.",
      "item": [
        {
          "name": "1. Create Complaint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.complaint) {",
                  "    pm.collectionVariables.set('COMPLAINT_OBJECT_ID', res.data.complaint._id);",
                  "    pm.collectionVariables.set('COMPLAINT_ID', res.data.complaint.complaintId);",
                  "    console.log('✅ Complaint ID saved:', res.data.complaint.complaintId);",
                  "}",
                  "",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has complaint data', function () {",
                  "    pm.expect(res.success).to.be.true;",
                  "    pm.expect(res.data.complaint).to.have.property('complaintId');",
                  "    pm.expect(res.data.complaint).to.have.property('title');",
                  "    pm.expect(res.data.complaint).to.have.property('category');",
                  "    pm.expect(res.data.complaint).to.have.property('priority');",
                  "    pm.expect(res.data.complaint).to.have.property('status');",
                  "    pm.expect(res.data.complaint).to.have.property('department');",
                  "});",
                  "",
                  "pm.test('Auto-assignment info present', function () {",
                  "    pm.expect(res.data).to.have.property('autoAssignment');",
                  "    pm.expect(res.data).to.have.property('duplicateDetection');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/complaints", "host": ["{{BASE_URL}}"], "path": ["api", "complaints"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Pothole on MG Road near Metro Station\",\n  \"description\": \"There is a large pothole on MG Road near the metro station entrance. It is causing traffic congestion and is dangerous for two-wheelers.\",\n  \"category\": \"Potholes\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946,\n  \"address\": \"MG Road, Near Metro Station, Bangalore - 560001\",\n  \"wardNumber\": 15,\n  \"images\": [\n    \"https://example.com/pothole1.jpg\",\n    \"https://example.com/pothole2.jpg\"\n  ]\n}"
            }
          }
        },
        {
          "name": "1b. Create Duplicate Complaint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Duplicate detected', function () {",
                  "    pm.expect(res.data.duplicateDetection.isDuplicate).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/complaints", "host": ["{{BASE_URL}}"], "path": ["api", "complaints"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Another pothole near MG Road metro\",\n  \"description\": \"The pothole near MG Road metro station has gotten bigger and is now a safety hazard for pedestrians crossing the road.\",\n  \"category\": \"Potholes\",\n  \"latitude\": 12.9718,\n  \"longitude\": 77.5948,\n  \"address\": \"MG Road, Near Metro Station Exit B, Bangalore - 560001\",\n  \"wardNumber\": 15\n}"
            }
          }
        },
